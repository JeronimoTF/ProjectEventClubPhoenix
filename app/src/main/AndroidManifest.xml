        <activity
            android:name=".auth.registro.Confirmacion"
            android:exported="false" />
        <activity
            android:name=".auth.registro.Contrasena"
            android:exported="false" />
        <activity
            android:name=".auth.registro.RegistroLocalizacionUsu"
            android:exported="false" />
        <activity
            android:name=".auth.registro.RegistroDatos"
            android:exported="false" />
        <activity
            android:name=".auth.login.Login"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".vista_usuario.bienvenida.activity_bienvenida"
            android:exported="false" />
        <activity
            android:name=".vista_usuario.bienvenida.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>