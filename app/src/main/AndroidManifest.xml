        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProjectEventClub">
        <activity
            android:name=".auth.rec_contrasena.ErrorCambioContrasena"
            android:exported="false" />
        <activity
            android:name=".auth.rec_contrasena.ContrasenaCambiadaExitosamente"
            android:exported="false" />
        <activity
            android:name=".auth.rec_contrasena.NuevaContrasena"
            android:exported="false" />
        <activity
            android:name=".auth.rec_contrasena.CodigoVerificacion"
            android:exported="false" />
        <activity
            android:name=".auth.rec_contrasena.RecuperarContrasena"
