<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fondo_opaco">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- LOGO -->
            <ImageView
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginTop="30dp"
                android:src="@drawable/logo"
                android:layout_marginBottom="16dp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tituloREcContra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recupera_tu_contrase_a"
                android:textStyle="bold"
                android:textColor="@color/navbar_background"
                android:textSize="20sp"
                android:layout_marginTop="20dp" />



            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCodigoConfir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/ingresa_el_codigo_de_confirmacion"
                android:layout_marginTop="30sp"
                android:textColor="@color/navbar_background"
                android:inputType="textPersonName" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnREcuperaContra2"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                android:layout_gravity="center"
                android:textColor="@color/navbar_background"
                android:fontFamily="serif"
                android:textSize="18sp"
                android:textStyle="bold"
                app:strokeColor="@color/navbar_background"
                app:strokeWidth="3dp"
                android:text="@string/enviar_codigo"
                android:layout_marginTop="150dp"
                app:cornerRadius="24dp" />

            <TextView
                android:id="@+id/DescripcionRecCuenta_CorreoElectro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:layout_marginTop="120sp"
                android:text="@string/DescripCodigoCofir_CambiContra"
                android:textAlignment="center"
                android:textColor="@color/navbar_background"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>