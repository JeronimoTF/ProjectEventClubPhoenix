<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header con botón volver -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnVolverPendientes"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_revert"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/pedidos_pendientes"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/navbar_background"/>

    </LinearLayout>

    <!-- Lista vacía -->
    <TextView
        android:id="@+id/tvSinPedidos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_hay_pedidos_pendientes"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#9E9E9E"
        android:padding="32dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPedidosPendientes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>