<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">


    <!-- Back Button Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingTop="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBackConEveUsu2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/black" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nombre del evento -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_nameevent_consultevent"
                android:textColor="@color/navbar_background"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/EditTxtNomEveUsu2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:layout_marginBottom="15dp"
                android:background="@drawable/style_edit_txt"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:hint="@string/txt_nameevent_consultevent"/>

            <!-- Fecha y hora -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_consultevent_datetime"
                android:textColor="@color/navbar_background"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/EditTxtFecHorEveUsu2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/style_edit_txt"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="@string/txt_consultevent_datetime" />

            <!-- Descripción -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_consultevent_descriptionbox"
                android:textColor="@color/navbar_background"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/EditTxtDesEveUsu2"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/style_edit_txt"
                android:gravity="top"
                android:padding="12dp"
                android:hint="@string/txt_consultevent_descriptionbox" />

            <!-- Localidad - zona -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_consultevent_localidad"
                android:textColor="@color/navbar_background"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/EditTxtLocZonUsu2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/style_edit_txt"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="@string/txt_consultevent_localidad" />

            <!-- Piso - Silla -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_consultevent_chair"
                android:textColor="@color/navbar_background"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/EditTxtPisoSillaUsu2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/style_edit_txt"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="@string/txt_consultevent_chair"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
