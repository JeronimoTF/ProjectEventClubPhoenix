<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_opaco"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/logo" />

    <ImageView
        android:layout_width="260dp"
        android:layout_height="140dp"
        android:layout_marginTop="45dp"
        android:src="@drawable/ticketvalido1" />

    <TextView
        android:id="@+id/txt_success_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:text="@string/txt_asistance_exitosa"
        android:textColor="#1A4373"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnAsistencia_volver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="40dp"
        android:text="@string/volver"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/navbar_background"
        app:icon="@android:drawable/btn_star_big_on"
        app:iconPadding="8dp"
        app:iconTint="@color/navbar_background"
        app:iconGravity="textStart"
        android:background="@drawable/style_buttons"
        app:backgroundTint="@null" />
</LinearLayout>
