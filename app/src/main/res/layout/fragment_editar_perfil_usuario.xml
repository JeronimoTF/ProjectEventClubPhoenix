<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <TextView
        android:id="@+id/TituloPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/editar_perfil_de_usuario"
        android:textAlignment="center"
        android:textColor="@color/navbar_background"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Foto redonda con ícono de cámara -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="4dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="6dp">

                    <ImageView
                        android:id="@+id/iv_editar_foto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_logo"
                        android:contentDescription="@string/foto_de_perfil" />

                </androidx.cardview.widget.CardView>

                <!-- Ícono de cámara sobre la foto -->
                <ImageView
                    android:id="@+id/iv_camara_icon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:src="@android:drawable/ic_menu_camera"
                    android:padding="6dp"
                    android:contentDescription="cambiar foto" />

            </FrameLayout>

            <TextView
                android:id="@+id/tituloDatosUsus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/datos_del_usuario"
                android:textStyle="bold"
                android:textColor="@color/navbar_background"
                android:textSize="20sp"
                android:layout_marginTop="20dp" />


            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/nombres"
                android:layout_marginTop="30sp"
                android:textColor="@color/navbar_background"
                android:inputType="textPersonName" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApellidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/apellidos"
                android:inputType="textPersonName" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEdad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/edad"
                android:inputType="number" />

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/genero" />

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spTipoDocumento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/tipo_de_documento" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDocumento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/numero_de_documento"
                android:inputType="number" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/fecha_de_nacimiento"
                android:focusable="false" />

            <!-- DATOS UBICACION -->
            <TextView
                android:id="@+id/tituloDatosUsusLoca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/datos_de_ubicacion_del_usuario"
                android:textStyle="bold"
                android:textColor="@color/navbar_background"
                android:textSize="20sp"
                android:layout_marginTop="20dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCelular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/celular"
                android:layout_marginTop="30sp"
                android:textColor="@color/navbar_background"
                android:inputType="textPersonName" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/correo"
                android:inputType="textPersonName" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCiudadResi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/ciudad_de_residencia"
                android:inputType="number" />

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spLocalidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/localidad" />

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spBarrio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/barrio" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/direcci_n"
                android:inputType="number" />

            <TextView
                android:id="@+id/tituloDatosUsusLoca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulocontrase_a"
                android:textStyle="bold"
                android:textColor="@color/navbar_background"
                android:textSize="20sp"
                android:layout_marginTop="20dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/contrase_ausu"
                    android:layout_marginTop="30sp"
                    android:textColor="@color/navbar_background"
                    android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRecontra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="@string/confirmar_contrase_a"
                    android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- BOTÓN GUARDAR CAMBIOS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarCambios"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                android:layout_gravity="center"
                android:textColor="@color/navbar_background"
                android:fontFamily="serif"
                android:textSize="18sp"
                android:textStyle="bold"
                app:strokeColor="@color/navbar_background"
                app:strokeWidth="3dp"
                android:text="@string/guardar_cambios"
                android:layout_marginTop="50dp"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>