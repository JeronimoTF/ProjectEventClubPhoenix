<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fondo_opaco">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- LOGO -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="26dp"
            android:src="@drawable/logo"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/navbar_background"
            android:hint="@string/correo_o_usuario"
            android:inputType="textEmailAddress" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:endIconMode="password_toggle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/navbar_background"
            android:hint="@string/contrase_a"
            android:inputType="textPassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- BOTONES -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUsuario"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/white"
        android:layout_gravity="center"
        android:textColor="@color/navbar_background"
        android:fontFamily="serif"
        android:textSize="18sp"
        android:textStyle="bold"
        app:strokeColor="@color/navbar_background"
        app:strokeWidth="3dp"
        android:text="@string/ingresar_como_usuario"
        android:layout_marginTop="24dp"
        app:icon="@drawable/ic_launcher_foreground"
        app:cornerRadius="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAnfitrion"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/white"
        android:layout_gravity="center"
        android:textColor="@color/navbar_background"
        android:fontFamily="serif"
        android:textSize="18sp"
        android:textStyle="bold"
        app:strokeColor="@color/navbar_background"
        app:strokeWidth="3dp"
        android:text="@string/ingresar_como_anfitrion"
        android:layout_marginTop="12dp"
        app:icon="@drawable/ic_launcher_foreground"
        app:cornerRadius="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogle"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        app:icon ="@drawable/google"
        android:backgroundTint="@color/white"
        android:layout_gravity="center"
        android:textColor="@color/navbar_background"
        android:fontFamily="serif"
        android:textSize="18sp"
        android:textStyle="bold"
        app:strokeColor="@color/navbar_background"
        app:strokeWidth="3dp"
        android:text="@string/ingresar_con_google"
        android:layout_marginTop="12dp"
        app:cornerRadius="24dp" />

    <!-- TEXTO REGISTRO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_tienes_cuenta_registrate"
        android:textColor="@color/navbar_background"
        android:textSize="14sp"
        android:layout_marginTop="24dp" />

    <!-- RECUPERAR CONTRASEÑA -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/olvidaste_tu_contrase_a"
        android:textColor="@color/navbar_background"
        android:textSize="13sp"
        android:layout_marginTop="12dp" />

    <!-- HUELLA -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="15dp"
        android:src="@drawable/ic_launcher_foreground"
        android:textColor="@android:color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ingresa_con_huella"
            android:textColor="@color/navbar_background"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>
    </ScrollView>
</LinearLayout>
