<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingTop="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBackConEveUsu1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/black" />
    </LinearLayout>

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Nombre del evento -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_nameevent_consultevent"
            android:textColor="@color/navbar_background"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/EditTxtConEveUsu1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/style_edit_txt"
                android:paddingStart="16dp"
                android:paddingEnd="60dp"
                android:hint="@string/txt_nameevent_consultevent"/>

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="5dp"
                android:background="@android:drawable/screen_background_light_transparent"
                android:padding="8dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/black"
                android:contentDescription="@null" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_consultevent_date"
            android:textColor="@color/navbar_background"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/EditTxtFecEveUsu1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/style_edit_txt"
                android:paddingStart="16dp"
                android:paddingEnd="60dp"
                android:hint="@string/txt_consultevent_date"/>

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="5dp"
                android:background="@android:drawable/screen_background_light_transparent"
                android:padding="8dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/black"
                android:contentDescription="@null" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnConEveUsu1"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/style_buttons"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/black"
                android:contentDescription="@string/txt_consult_event" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/txt_consult_event"
                android:gravity="center"
                android:textColor="@color/navbar_background"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
