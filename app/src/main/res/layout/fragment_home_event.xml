<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".vista_usuario.main.usuarios.activity_usuarioPrincipal">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- TÍTULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bienvenido"
                android:textSize="26sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:textColor="@color/navbar_background"
                android:layout_marginTop="26dp"/>

            <!-- DESCRIPCIÓN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/InvitacionPromocional"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:textColor="@color/navbar_background"
                android:gravity="center"
                android:layout_marginTop="25dp"/>

            <!-- TÍTULO SECCIÓN EVENTOS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/eventos_pr_ximos"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/navbar_background"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="60dp"/>

            <!-- SCROLL HORIZONTAL DE EVENTOS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- EVENTO 1 -->
                    <LinearLayout
                        android:layout_width="200dp"
                        android:layout_height="260dp"
                        android:layout_marginEnd="12dp"
                        android:orientation="vertical"
                        android:background="@color/black"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:scaleType="centerCrop"
                            android:background="@drawable/concierto_cultural"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bogot"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- EVENTO 2 -->
                    <LinearLayout
                        android:layout_width="200dp"
                        android:layout_height="260dp"
                        android:layout_marginEnd="12dp"
                        android:orientation="vertical"
                        android:background="@color/black"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:scaleType="centerCrop"
                            android:src="@drawable/obra_infantil"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bogot"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- EVENTO 3 -->
                    <LinearLayout
                        android:layout_width="200dp"
                        android:layout_height="260dp"
                        android:orientation="vertical"
                        android:background="@color/black"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:scaleType="centerCrop"
                            android:src="@drawable/concierto_regue"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bogot"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- EVENTO 4 -->
                    <LinearLayout
                        android:layout_width="200dp"
                        android:layout_height="260dp"
                        android:orientation="vertical"
                        android:background="@color/black"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:scaleType="centerCrop"
                            android:src="@drawable/anime_sinfonico"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bogot"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- EVENTO 5 -->
                    <LinearLayout
                        android:layout_width="200dp"
                        android:layout_height="260dp"
                        android:orientation="vertical"
                        android:background="@color/black"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:scaleType="centerCrop"
                            android:src="@drawable/homymuje_alaplancha"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bogot"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>