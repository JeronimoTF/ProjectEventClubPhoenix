<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_opaco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".vista_usuario.main.usuarios.fragment_configUser">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/tv_editdatos"
                    android:textColor="@color/navbar_background"
                    android:textSize="34sp"
                    android:textStyle="bold|italic" />

                <EditText
                    android:id="@+id/et_nombres"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/style_edit_txt"
                    android:hint="@string/txt_edithint_name"
                    android:textColorHint="@color/navbar_background"
                    android:inputType="textPersonName"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/black" />

                <EditText
                    android:id="@+id/et_apellidos"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/style_edit_txt"
                    android:hint="@string/txt_edithint_lastname"
                    android:textColorHint="@color/navbar_background"
                    android:inputType="textPersonName"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/black" />

                <EditText
                    android:id="@+id/et_celular"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/style_edit_txt"
                    android:hint="@string/txt_edithint_celular"
                    android:textColorHint="@color/navbar_background"
                    android:inputType="phone"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/black" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_edithint_typedocument"
                    android:textColor="@color/navbar_background" />

                <Spinner
                    android:id="@+id/sp_typedocument"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/style_edit_txt" />

                <EditText
                    android:id="@+id/et_documento"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/style_edit_txt"
                    android:hint="@string/txt_edithint_document"
                    android:textColorHint="@color/navbar_background"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/tv_birthday"
                    android:textColor="@color/navbar_background"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/et_birthday"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/style_edit_txt"
                    android:focusable="false"
                    android:hint="@string/txt_edithint_ordenbirthday"
                    android:textColorHint="@color/navbar_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/black" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/change_correo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="15dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="40dp"
                        android:background="@drawable/style_buttons"
                        android:text="@string/change_correo"
                        android:textColor="@color/navbar_background"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:icon="@android:drawable/btn_star_big_on"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="@color/navbar_background" />

                    <Button
                        android:id="@+id/change_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="15dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="40dp"
                        android:background="@drawable/style_buttons"
                        android:text="@string/change_password"
                        android:textColor="@color/navbar_background"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:icon="@android:drawable/btn_star_big_on"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="@color/navbar_background" />
                </LinearLayout>

                <Button
                    android:id="@+id/confirm_editdatos"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="40dp"
                    android:background="@drawable/style_buttons"
                    android:text="@string/btn_save"
                    android:textColor="@color/navbar_background"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:icon="@android:drawable/btn_star_big_on"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="@color/navbar_background" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
