<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Usuario -->
        <TextView
            android:id="@+id/tvUsuarioPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"/>

        <!-- Proveedor -->
        <TextView
            android:id="@+id/tvProveedorPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#616161"
            android:layout_marginTop="4dp"/>

        <!-- Ubicación destacada -->
        <TextView
            android:id="@+id/tvUbicacionPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:layout_marginTop="6dp"/>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <!-- Items del pedido -->
        <TextView
            android:id="@+id/tvItemsPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#424242"
            android:lineSpacingExtra="4dp"/>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"/>

        <!-- Total -->
        <TextView
            android:id="@+id/tvTotalPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="end"/>

        <!-- Botón entregar (visible solo en pendientes) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEntregado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✓ Pedido Entregado"
            android:layout_marginTop="12dp"
            app:cornerRadius="24dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>